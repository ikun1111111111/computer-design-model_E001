  "制作工艺": [
    {
      "步骤": 1,
      "名称": "选皮",
      "说明": "选择优质驴皮、牛皮或羊皮，以驴皮为佳。皮质要求薄厚均匀，质地坚韧，透明度高。"
    },
    {
      "步骤": 2,
      "名称": "制皮",
      "说明": "将生皮浸泡在水中数日，刮去毛、肉和脂肪，然后绷在木框上晾干，反复打磨至薄厚均匀。"
    },
    {
      "步骤": 3,
      "名称": "画稿",
      "说明": "根据剧目需要，在纸上画出影人的各个部件图样，包括头、身、手、足等。"
    },
    {
      "步骤": 4,
      "名称": "过稿",
      "说明": "将画好的图样拓在皮革上，用针沿线条刺出小孔，形成轮廓。"
    },
    {
      "步骤": 5,
      "名称": "雕刻",
      "说明": "用各种刻刀沿着针孔轮廓雕刻，并刻出花纹装饰。雕刻技法有阳刻（留线去面）和阴刻（留面去线）两种。"
    },
    {
      "步骤": 6,
      "名称": "上色",
      "说明": "用透明颜料在雕刻好的皮片上着色，传统颜色有红、黄、绿、黑等，色彩要鲜艳透明。"
    },
    {
      "步骤": 7,
      "名称": "上油",
      "说明": "上色后涂上一层清油或桐油，保护颜色，增加透明度和耐用性。"
    },
    {
      "步骤": 8,
      "名称": "组装",
      "说明": "将头、身、手等部件用线或皮条连接起来，安装操纵杆（签子）。"
    },
    {
      "步骤": 9,
      "名称": "完成",
      "说明": "检查各部件是否灵活，修补瑕疵，一个完整的皮影人就制作完成了。"
    }
  ],
