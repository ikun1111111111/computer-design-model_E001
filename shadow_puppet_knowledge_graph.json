      "id": 19,
      "label": "制作工艺",
      "type": "工艺",
      "properties": {
        "流程数量": 9,
        "造型特点": {
          "五分侧面": "皮影人物多采用五分侧面造型，即半侧面",
          "戏曲脸谱": "生旦净末丑各行当脸谱化造型",
          "夸张变形": "突出人物特征，进行艺术夸张",
          "镂空雕刻": "大量使用镂空技法，增强透光效果",
          "色彩艳丽": "使用高饱和度色彩，对比强烈"
        }
      }
