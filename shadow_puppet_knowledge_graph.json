    {
      "id": 2,
      "label": "西汉-起源期",
      "type": "历史时期",
      "properties": {
        "朝代": "西汉",
        "时期": "起源期",
        "描述": "相传汉武帝爱妃李夫人病逝，方士李少翁用棉帛裁成李夫人影像，涂上色彩，在灯光下投影于帐幕，汉武帝远远望去，仿佛爱妃复活。这被认为是皮影戏的雏形。"
      }
    },
    {
      "id": 3,
      "label": "唐代-发展期",
      "type": "历史时期",
      "properties": {
        "朝代": "唐代",
        "时期": "发展期",
        "描述": "皮影戏在唐代得到进一步发展，成为宫廷和民间的娱乐形式。唐代佛教盛行，皮影戏也被用于宣传佛教故事。"
      }
    },
    {
      "id": 4,
      "label": "宋代-成熟期",
      "type": "历史时期",
      "properties": {
