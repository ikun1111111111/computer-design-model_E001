    {
      "id": 20,
      "label": "步骤1-选皮",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 1,
        "名称": "选皮",
        "说明": "选择优质驴皮、牛皮或羊皮，以驴皮为佳。皮质要求薄厚均匀，质地坚韧，透明度高。",
        "要点": [
          "皮质细腻",
          "厚度适中",
          "无伤痕",
          "透明度好"
        ]
      }
    },
    {
      "id": 21,
      "label": "步骤2-制皮",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 2,
        "名称": "制皮",
        "说明": "将生皮浸泡在水中数日，刮去毛、肉和脂肪，然后绷在木框上晾干，反复打磨至薄厚均匀。",
        "要点": [
          "浸泡时间适当",
          "刮皮均匀",
          "绷紧晾干",
          "反复打磨"
        ]
      }
    },
    {
      "id": 22,
      "label": "步骤3-画稿",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 3,
        "名称": "画稿",
        "说明": "根据剧目需要，在纸上画出影人的各个部件图样，包括头、身、手、足等。",
        "要点": [
          "比例准确",
          "线条流畅",
          "符合传统",
          "便于雕刻"
        ]
      }
    },
    {
      "id": 23,
      "label": "步骤4-过稿",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 4,
        "名称": "过稿",
        "说明": "将画好的图样拓在皮革上，用针沿线条刺出小孔，形成轮廓。",
        "要点": [
          "拓印清晰",
          "针孔均匀",
          "轮廓准确"
        ]
      }
    },
    {
      "id": 24,
      "label": "步骤5-雕刻",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 5,
        "名称": "雕刻",
        "说明": "用各种刻刀沿着针孔轮廓雕刻，并刻出花纹装饰。雕刻技法有阳刻（留线去面）和阴刻（留面去线）两种。",
        "要点": [
          "刀法熟练",
          "线条流畅",
          "花纹精美",
          "阳刻阴刻结合"
        ]
      }
    },
    {
      "id": 25,
      "label": "步骤6-上色",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 6,
        "名称": "上色",
        "说明": "用透明颜料在雕刻好的皮片上着色，传统颜色有红、黄、绿、黑等，色彩要鲜艳透明。",
        "要点": [
          "色彩鲜艳",
          "透明度好",
          "分层上色",
          "自然过渡"
        ]
      }
    },
    {
      "id": 26,
      "label": "步骤7-上油",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 7,
        "名称": "上油",
        "说明": "上色后涂上一层清油或桐油，保护颜色，增加透明度和耐用性。",
        "要点": [
          "油层均匀",
          "薄厚适中",
          "充分干燥"
        ]
      }
    },
    {
      "id": 27,
      "label": "步骤8-组装",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 8,
        "名称": "组装",
        "说明": "将头、身、手等部件用线或皮条连接起来，安装操纵杆（签子）。",
        "要点": [
          "连接灵活",
          "牢固可靠",
          "签子位置准确"
        ]
      }
    },
    {
      "id": 28,
      "label": "步骤9-完成",
      "type": "制作步骤",
      "properties": {
        "步骤序号": 9,
        "名称": "完成",
        "说明": "检查各部件是否灵活，修补瑕疵，一个完整的皮影人就制作完成了。",
